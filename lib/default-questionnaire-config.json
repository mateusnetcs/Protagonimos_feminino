        { "key": "idade", "text": "Qual a sua idade?", "type": "radio_list", "options": [{ "value": "MENOS DE 25 ANOS", "label": "Menos de 25 anos" }, { "value": "25-34", "label": "25 - 34 anos" }, { "value": "35-44", "label": "35 - 44 anos" }, { "value": "45-54", "label": "45 - 54 anos" }, { "value": "55 anos ou mais", "label": "55 anos ou mais" }] }
      ]
    },
    {
      "id": "step2",
      "title": "Sua Jornada",
