        { "key": "temas_aprender", "text": "Sobre quais temas gostaria de aprender mais?", "type": "checkbox", "options": [{ "value": "Como aumentar as vendas", "label": "Como aumentar as vendas", "emoji": "🚀" }, { "value": "Divulgar Instagram e WhatsApp", "label": "Divulgar (Insta/WhatsApp)", "emoji": "💬" }, { "value": "Organização financeira", "label": "Organização financeira", "emoji": "📈" }, { "value": "Precificação correta", "label": "Precificação correta", "emoji": "🏷️" }, { "value": "Empreendedorismo feminino", "label": "Empreendedorismo feminino", "emoji": "💪" }] },
        { "key": "sugestao", "text": "Qual a sua sugestão para tornarmos a próxima feirinha ainda melhor?", "type": "textarea", "placeholder": "Deixe aqui a sua opinião..." }
      ]
