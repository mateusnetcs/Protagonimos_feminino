        { "key": "controla_financas", "text": "Controla os seus ganhos e despesas?", "type": "radio_binary", "options": [{ "value": "SIM", "label": "SIM" }, { "value": "NÃO", "label": "NÃO" }] },
        { "key": "dificuldades", "text": "Quais são as suas maiores dificuldades hoje?", "type": "checkbox", "options": [{ "value": "Falta de clientes", "label": "Falta de clientes", "emoji": "🤷‍♀️" }, { "value": "Preço baixo dos produtos", "label": "Preço baixo dos produtos", "emoji": "📉" }, { "value": "Falta de divulgação", "label": "Falta de divulgação", "emoji": "🤫" }, { "value": "Organização financeira", "label": "Organização financeira", "emoji": "🧾" }, { "value": "Acesso a crédito", "label": "Acesso a crédito", "emoji": "🏦" }, { "value": "Transporte", "label": "Transporte", "emoji": "🚚" }] }
