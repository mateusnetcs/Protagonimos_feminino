        { "key": "locais_venda", "text": "Onde vende os seus produtos?", "type": "checkbox", "options": [{ "value": "Feirinha local", "label": "Feirinha local", "emoji": "🎪" }, { "value": "Encomendas", "label": "Encomendas", "emoji": "📦" }, { "value": "Redes sociais", "label": "Redes sociais", "emoji": "📱" }, { "value": "Para mercados", "label": "Para mercados", "emoji": "🛒" }] }
      ]
    },
    {
      "id": "step4",
      "title": "O Dia a Dia",
      "subtitle": "Rotina 📊",
      "questions": [
