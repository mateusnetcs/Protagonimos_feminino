        { "key": "renda_agricultura", "text": "A agricultura é a sua principal fonte de renda?", "type": "radio_binary", "options": [{ "value": "SIM", "label": "SIM" }, { "value": "NÃO", "label": "NÃO" }] }
      ]
    },
    {
