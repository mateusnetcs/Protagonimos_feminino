# MySQL (obrigatório) - NÃO defina MYSQL_USER no Coolify (usa root por padrão)
MYSQL_PASSWORD=sua_senha_segura
MYSQL_DATABASE=jornada_produtor

# NextAuth (obrigatório)
NEXTAUTH_SECRET=gere-uma-chave-secreta-longa-aqui
NEXTAUTH_URL=https://seu-dominio.com

# URL base da aplicação (para OAuth callback Mercado Pago)
APP_URL=https://seu-dominio.com

# OpenAI — legendas, posts com IA e chat assistente do painel
OPENAI_API_KEY=
# openai | dreamina | auto — sempre usa a foto cadastrada do produto (obrigatória)
POST_IMAGE_PROVIDER=openai
OPENAI_IMAGE_MODEL=gpt-image-1
# Quantas artes com layouts diferentes gerar por clique (1 a 9, padrão 2)
POST_IMAGE_VARIANT_COUNT=2

# Dreamina/UseAPI (opcional — só se POST_IMAGE_PROVIDER=dreamina)
USEAPI_TOKEN=

# remove.bg (opcional - fotos de produtos com fundo branco na importação de nota)
# 50 chamadas grátis/mês: https://www.remove.bg/api
# IMPORTANTE: Adicione em .env.local (não aqui) e reinicie o servidor após alterar
REMOVEBG_API_KEY=sua-chave-removebg-aqui

# Migrações em produção (Coolify): não rode npm install no container.
# Execute database/migrations/run_prod_deploy.sql no painel MySQL do Coolify.
# Uploads (galeria de posts, fotos de produtos): volume persistente em /app/public/uploads

# Mercado Pago (opcional - catálogo e PDV PIX)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_APP_ID=
MERCADOPAGO_APP_SECRET=
