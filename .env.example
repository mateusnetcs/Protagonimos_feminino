# MySQL (obrigatório) - NÃO defina MYSQL_USER no Coolify (usa root por padrão)
MYSQL_PASSWORD=sua_senha_segura
MYSQL_DATABASE=jornada_produtor

# NextAuth (obrigatório)
NEXTAUTH_SECRET=gere-uma-chave-secreta-longa-aqui
NEXTAUTH_URL=https://seu-dominio.com

# URL base da aplicação (para OAuth callback Mercado Pago)
APP_URL=https://seu-dominio.com

# OpenAI (opcional - geração de posts com GPT)
OPENAI_API_KEY=sk-proj-sua-chave-openai-aqui

# Dreamina/UseAPI (opcional - imagens para posts)
USEAPI_TOKEN=

# remove.bg (opcional - fotos de produtos com fundo branco na importação de nota)
# 50 chamadas grátis/mês: https://www.remove.bg/api
# IMPORTANTE: Adicione em .env.local (não aqui) e reinicie o servidor após alterar
REMOVEBG_API_KEY=sua-chave-removebg-aqui

# Mercado Pago (opcional - catálogo e PDV PIX)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_APP_ID=
MERCADOPAGO_APP_SECRET=
